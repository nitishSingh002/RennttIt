<% layout('layouts/boilerplate') %>

<div class="container d-flex justify-content-center align-items-center" style="min-height: 80vh;">
    
    <div class="text-center">

        <h1 class="display-1 text-danger fw-bold">
            <%= err.status || 500 %>
        </h1>

        <h2 class="mb-3">Oops! Something went wrong 😢</h2>

        <p class="lead text-muted">
            <%= err.message || "Internal Server Error" %>
        </p>

        <div class="mt-4">
            <a href="/" class="btn btn-dark px-4 me-2">🏠 Home</a>
            <button onclick="history.back()" class="btn btn-outline-secondary px-4">⬅ Go Back</button>
        </div>

    </div>

</div>